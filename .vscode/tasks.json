{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "create-bin",
      "type": "shell",
      "command": "cmd",
      "args": [
        "/c",
        "if not exist \"${workspaceFolder}\\bin\" mkdir \"${workspaceFolder}\\bin\""
      ],
      "problemMatcher": []
    },
    {
      "label": "build active file",
      "type": "shell",
      "dependsOn": "create-bin",
      "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
      "args": [
        "-g",
        "${file}",
        "-o",
        "${workspaceFolder}\\bin\\${fileBasenameNoExtension}.exe"
      ],
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "echo": true, "reveal": "always", "panel": "shared" },
      "problemMatcher": ["$gcc"]
    }
  ]
}
{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe 生成活动文件",
            "command": "C:\\msys64\\ucrt64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "C:\\msys64\\ucrt64\\bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "调试器生成的任务。"
        }
    ],
    "version": "2.0.0"
}